# ==================== FRONTEND CONFIGURATION ====================

# API Configuration
# Production (recommended with reverse proxy): /api
# Local development alternative: http://localhost:8000/api
VITE_API_URL=/api

# App name display
VITE_APP_NAME=AI Mail Assistant with AI-Powered Email Management

# Environment
NODE_ENV=development

# Optional: API timeout (in milliseconds)
VITE_API_TIMEOUT=30000

